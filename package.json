{
    "name": "bun-svelte-builder",
    "bin": {
        "bun-svelte-builder": "./packages/bun-svelte-builder/src/cli.ts"
    },
    "version": "0.0.0",
    "module": "./packages/bun-svelte-builder/src/index.ts",
    "type": "module",
    "exports": {
        ".": "./packages/bun-svelte-builder/src/index.ts",
        "./runtime": "./packages/bun-svelte-builder/src/runtime.ts",
        "./build": "./packages/bun-svelte-builder/src/build.ts",
        "./package.json": "./package.json"
    },
    "files": [
        "packages/bun-svelte-builder/src",
        "README.md",
        "package.json"
    ],
    "workspaces": [
        "examples"
    ],
    "devDependencies": {
        "@types/bun": "latest",
        "svelte": "next"
    },
    "peerDependencies": {
        "svelte": "next",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "bun run build.ts",
        "check": "bun run typecheck && bun test",
        "dev": "bun --hot server.ts",
        "test": "bun test",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
